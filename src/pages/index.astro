---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
---

<Layout title={`${SITE.title} | Blog`} description={SITE.desc}>
  <Header />
  <main id="main-content" class="app-layout py-10">
    <section class="border-b border-border pb-6">
      <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">Blog</h1>
      <p class="mt-4 max-w-2xl text-lg text-foreground/78">
        Personal writing on software, work, and things worth keeping.
      </p>
    </section>

    <section class="py-4">
      <ul>
        {sortedPosts.map(post => <Card variant="h3" {...post} />)}
      </ul>
    </section>
  </main>
  <Footer />
</Layout>
