---
type Props = {
  pageTitle: string;
  pageDesc?: string;
};

const { pageTitle, pageDesc } = Astro.props;
---

<main id="main-content" class="app-layout py-10">
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{pageTitle}</h1>
  {pageDesc && <p class="mt-3 max-w-2xl text-foreground/75">{pageDesc}</p>}
  <slot />
</main>
