---
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import { SITE } from "@/config";

const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header class="app-layout border-b border-border py-5">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <a href="/" class="text-xl font-semibold tracking-tight sm:text-2xl">
      {SITE.title}
    </a>

    <nav aria-label="Primary navigation">
      <ul class="flex flex-wrap items-center gap-x-5 gap-y-3 text-sm font-medium">
        <li>
          <a href="/" class:list={{ "active-nav": currentPath === "/" }}>Blog</a>
        </li>
        <li>
          <a
            href="https://www.jaimechapinal.com"
            target="_blank"
            rel="noreferrer"
          >
            Website
          </a>
        </li>
        <li>
          <a href="/rss.xml">RSS</a>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li>
              <button
                id="theme-btn"
                class="focus-outline relative size-8 hover:[&>svg]:stroke-accent"
                title="Toggles light & dark"
                aria-label="auto"
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>
